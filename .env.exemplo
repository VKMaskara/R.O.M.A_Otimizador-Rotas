# Provedor de Mapas (Valores: google ou ors)
MAPS_PROVIDER=ors

# Chaves de API
GOOGLE_MAPS_API_KEY=sua_chave_do_google
ORS_API_KEY=sua_chave_do_open_route_service

# Modo de entrada de dados: excel | ocr | manual (padrão: excel)
INPUT_MODE=excel

# Caminho do arquivo de entrada (usado nos modos excel e ocr)
# INPUT_FILE=data/input_enderecos.xlsx

# JWT
 JWT_SECRET=minha_chave_super_secreta